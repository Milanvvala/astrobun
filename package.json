{
  "name": "astrobun",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "client": "astro dev",
    "build:client": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "worker": "wrangler dev",
    "dev": "bun run client",
    "dryrun:staging": "bun run build:client && wrangler deploy --dry-run --env staging",
    "dryrun:prod": "bun run build:client && wrangler deploy --dry-run --env production",
    "deploy:staging": "bun run build:client && wrangler deploy --env staging",
    "deploy:prod": "bun run build:client && wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply dojo_local_db --local",
    "db:migrate:staging": "wrangler d1 migrations apply dojo_staging_db --remote --env staging",
    "create:test:db": "bun run ./lib/create-test-db.ts",
    "destory:test:db": "bun run ./lib/delete-test-db.ts",
    "test": "bun run create:test:db && bun test && bun run destory:test:db",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.9",
    "@astrojs/react": "^4.2.0",
    "@astrojs/vue": "^6.0.1",
    "@knadh/oat": "^0.4.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vue-dnd-kit/core": "^2.4.4",
    "astro": "^6.0.4",
    "concurrently": "^9.2.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "^0.3.1",
    "hono": "^4.12.8",
    "jose": "^6.2.1",
    "lucide-vue-next": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remixicon": "^4.9.1",
    "vue": "^3.5.32",
    "wrangler": "^4.82.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260316.1",
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.9"
  }
}