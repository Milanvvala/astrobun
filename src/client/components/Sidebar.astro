      Switch theme
    </button>
  </footer>
</aside>

<style>
  aside[data-sidebar] {
    padding: 0;
  }

  aside[data-sidebar] a {
    gap: var(--space-3);
  }

  aside[data-sidebar] details > summary {
    gap: var(--space-3);
  }

  aside[data-sidebar] footer button {
    width: 100%;
    justify-content: flex-start;
  }

  :global([data-theme="dark"]) .icon-light { display: none; }
  :global([data-theme="dark"]) .icon-dark { display: block; }
  :global(:not([data-theme="dark"])) .icon-light { display: block; }
  :global(:not([data-theme="dark"])) .icon-dark { display: none; }
</style>
