---
import Layout from "@/layouts/Layout.astro";
import { MapPin, Music, BookOpen, Heart } from "@lucide/astro";
import { Github, X, Youtube } from "simple-icons-astro";
---

<Layout title="Bio" description="my bio links">
  <main class="container p-4">
    <div class="row justify-center flex items-center">
      <div class="col-12 text-center" style="max-width: 520px;">
        
        <figure data-variant="avatar" class="bio-avatar">
          <img src="https://api.dicebear.com/9.x/micah/svg?seed=risebox" alt="Profile" />
        </figure>
        
        <div class="mt-4  items-center">
          <h1 class="mb-1">John Doe</h1>
          <p class="text-light">@johndoe</p>
          <div class="hstack gap-2 justify-center mt-2">
            <span class="badge secondary">Developer</span>
            <span class="badge">Creator</span>
            <span class="badge warning">Open Source</span>
          </div>
        </div>
        
        <p class="mt-4 mb-0">Developer, creator, and coffee enthusiast. Building things that matter.</p>
        <div class="mt-2">
          <span class="hstack gap-1 text-light justify-center">
            <MapPin size={14} /> San Francisco, CA
          </span>
        </div>

        <section class="mt-4">
          <div class="vstack gap-2">
            <a href="https://github.com" target="_blank" class="button outline w-100">
              <Github /> GitHub
            </a>
            <a href="https://twitter.com" target="_blank" class="button outline w-100">
              <X /> Twitter
            </a>
            <a href="https://youtube.com" target="_blank" class="button outline w-100">
              <Youtube /> YouTube
            </a>
            <a href="mailto:hello@johndoe.com" class="button primary w-100">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Get in Touch
            </a>
          </div>
        </section>

        <section class="mt-4">
          <h3 class="mb-2">Featured</h3>
          <article class="card">
            <header class="hstack justify-between p-2" style="border-bottom: 1px solid var(--border);">
              <span class="badge secondary">Blog</span>
              <span class="text-light small">2 days ago</span>
            </header>
            <div class="p-3">
              <h4 class="mb-2">Building Scalable Apps with Astro</h4>
              <p class="text-light small mb-0">Learn how to build fast, performant web applications.</p>
            </div>
            <footer class="hstack justify-between p-2" style="border-top: 1px solid var(--border);">
              <button class="ghost small"><Heart size={14} /> 24</button>
              <a href="#" class="small">Read more →</a>
            </footer>
          </article>
        </section>

        <section class="mt-4">
          <h3 class="mb-2">Now Playing</h3>
          <article class="card">
            <div class="p-3 hstack gap-3">
              <div class="music-icon">
                <Music size={24} color="white" />
              </div>
              <div class="flex-grow-1">
                <p class="mb-1 fw-500">Midnight City</p>
                <p class="text-light small mb-0">M83 • Hurry Up, We're Dreaming</p>
              </div>
            </div>
            <div class="p-2" style="border-top: 1px solid var(--border);">
              <progress value="45" max="100" class="w-100"></progress>
              <div class="hstack justify-between text-light small mt-1">
                <span>1:45</span>
                <span>4:00</span>
              </div>
            </div>
          </article>
        </section>

        <section class="mt-4">
          <h3 class="mb-2">Projects</h3>
          <div class="row">
            <article class="card col-6 p-3">
              <span class="badge success mb-2">Open Source</span>
              <h4 class="mb-1">OpenDash</h4>
              <p class="text-light small mb-0">Dashboard template</p>
            </article>
            <article class="card col-6 p-3">
              <span class="badge secondary mb-2">Product</span>
              <h4 class="mb-1">RiseBox</h4>
              <p class="text-light small mb-0">Productivity app</p>
            </article>
          </div>
        </section>

        <section class="mt-4 mb-4">
          <article class="card p-4" style="background: var(--secondary);">
            <div class="hstack gap-3">
              <BookOpen size={24} />
              <div>
                <h4 class="mb-1">Newsletter</h4>
                <p class="text-light small mb-0">Get weekly updates on web dev.</p>
              </div>
            </div>
            <fieldset class="group mt-3">
              <input type="email" placeholder="your@email.com" />
              <button type="button" class="small">Subscribe</button>
            </fieldset>
          </article>
        </section>

        <footer class="mt-4 mb-4">
          <p class="text-lighter small mb-0">© 2026 John Doe. Made with <a href="/">RiseBox</a></p>
        </footer>

      </div>
    </div>
  </main>
</Layout>

<style>
  .bio-avatar {
    width: 100px;
    height: 100px;
    margin: 0 auto;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--primary);
  }
  .bio-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .music-icon {
    width: 56px;
    height: 56px;
    background: var(--primary);
    border-radius: var(--radius-m);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .flex-grow-1 {
    flex: 1;
  }
  .fw-500 {
    font-weight: 500;
  }
  progress {
    height: 6px;
    border-radius: 3px;
  }
</style>
