---
import Layout from "@/layouts/Layout.astro";

const activePath = Astro.url.pathname;

function isActive(path: string) {
  return activePath === path;
}
---

<Layout title="dashboard" description="dashboard">
  <div class="dashboard-layout">
    <aside class="sidebar" data-sidebar>
      <nav>
        <ul>
          <li>
            <a href="/" aria-current={isActive("/") ? "page" : undefined}>Home</a>
          </li>
          <li>
            <a href="/dashboard" aria-current={isActive("/dashboard") ? "page" : undefined}>Dashboard</a>
          </li>
          <li>
            <details>
              <summary>Settings</summary>
              <ul>
                <li><a href="/settings/profile" aria-current={isActive("/settings/profile") ? "page" : undefined}>Profile</a></li>
                <li><a href="/settings/preferences" aria-current={isActive("/settings/preferences") ? "page" : undefined}>Preferences</a></li>
              </ul>
            </details>
          </li>
        </ul>
      </nav>
    </aside>

    <main class="dashboard-main">
      <div class="content-header">
        <h1>Dashboard</h1>
        <p>Welcome to your dashboard</p>
      </div>

      <div class="stats-grid">
        <article class="card" ot-animate="hover:pop">
          <header><h3>Total Users</h3></header>
          <p class="stat-value">1,234</p>
          <footer><small>+12% from last month</small></footer>
        </article>

        <article class="card" ot-animate="hover:pop">
          <header><h3>Active Sessions</h3></header>
          <p class="stat-value">89</p>
          <footer><small>Currently online</small></footer>
        </article>

        <article class="card" ot-animate="hover:pop">
          <header><h3>Revenue</h3></header>
          <p class="stat-value">$12,450</p>
          <footer><small>+8% from last month</small></footer>
        </article>

        <article class="card" ot-animate="hover:pop">
          <header><h3>Tasks</h3></header>
          <p class="stat-value">23</p>
          <footer><small>5 pending</small></footer>
        </article>
      </div>

      <section class="recent-activity">
        <h2>Recent Activity</h2>
        <article class="card" ot-animate="onview:slide-left">
          <div class="activity-item">
            <strong>New user registered</strong>
            <span>2 minutes ago</span>
          </div>
        </article>
        <article class="card" ot-animate="onview:slide-left">
          <div class="activity-item">
            <strong>Payment received</strong>
            <span>15 minutes ago</span>
          </div>
        </article>
        <article class="card" ot-animate="onview:slide-left">
          <div class="activity-item">
            <strong>Task completed</strong>
            <span>1 hour ago</span>
          </div>
        </article>
      </section>
    </main>
  </div>
</Layout>

<style>
  .dashboard-layout {
    display: flex;
    min-height: 100vh;
  }

    .sidebar {
      width: 250px;
      background: var(--card);
      border-right: 1px solid var(--border);
      padding: 1rem;
    }

  .sidebar ul {
    list-style: none;
    padding: 0;
  }

  .sidebar li {
    margin: 0.5rem 0;
  }

  .sidebar a {
    display: block;
    padding: 0.5rem 1rem;
    text-decoration: none;
    border-radius: 4px;
  }

  .sidebar a[aria-current="page"] {
    background: var(--primary);
    color: var(--primary-fg);
  }

  .sidebar details summary {
    cursor: pointer;
    padding: 0.5rem 1rem;
  }

  .sidebar details ul {
    margin-left: 1rem;
  }

  .dashboard-main {
    flex: 1;
    padding: 2rem;
    overflow-y: auto;
  }

  .content-header {
    margin-bottom: 2rem;
  }

  .content-header h1 {
    margin: 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: bold;
    margin: 1rem 0;
  }

  .recent-activity h2 {
    margin-bottom: 1rem;
  }

  .activity-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
</style>